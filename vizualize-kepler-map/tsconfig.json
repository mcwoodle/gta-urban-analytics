{
  "compilerOptions": {
    "sourceMap": true,
    "module": "commonjs",
    "target": "es2020",
    "lib": ["es2020", "dom", "dom.iterable"],
    "jsx": "react",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "strict": false,
    "noImplicitAny": false
  },
  "include": ["src"],
  "compileOnSave": false
}
